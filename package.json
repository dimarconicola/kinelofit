{
  "name": "kinelo-fit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:bootstrap": "npm run catalog:bootstrap",
    "db:setup": "npm run db:push && npm run db:bootstrap",
    "test": "npm run test:vitest && npm run test:node",
    "test:vitest": "vitest run",
    "test:node": "node --import tsx --test tests/filters.test.ts tests/freshness-adapters.test.ts tests/freshness.test.ts tests/policy.test.ts tests/readiness.test.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "catalog:bootstrap": "node --import tsx scripts/bootstrap-catalog.ts",
    "readiness": "node --import tsx scripts/check-readiness.ts",
    "freshness:run": "node --import tsx scripts/run-freshness.ts",
    "validate:import": "node --import tsx scripts/validate-import.ts data/imports/palermo_seed.csv",
    "research:build": "bash scripts/build-palermo-research-db.sh",
    "research:report": "bash scripts/report-palermo-research-db.sh",
    "catalog:export": "node --import tsx scripts/export-palermo-catalog.ts",
    "catalog:sync": "npm run research:build && npm run catalog:export"
  },
  "dependencies": {
    "@heroui/react": "^2.8.10",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^15.2.0",
    "@sentry/nextjs": "^10.43.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.43.1",
    "framer-motion": "^12.36.0",
    "luxon": "^3.6.1",
    "mapbox-gl": "^3.13.0",
    "next": "^15.2.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/luxon": "^3.4.2",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
